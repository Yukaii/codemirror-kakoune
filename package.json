{
  "name": "codemirror-kakoune",
  "version": "0.1.2",
  "description": "A CodeMirror 6 extension that brings Kakoune-style modal editing to the browser.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/playground"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yukaii/codemirror-kakoune.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:lib && pnpm build:playground",
    "build:lib": "tsc -p tsconfig.build.json",
    "build:playground": "vite build",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@lezer/highlight": "^1.2.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "codemirror": "^6.0.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
